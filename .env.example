# Backend environment example
# Copy to .env and adjust for your environment

# Supabase Postgres (use the connection pooler port 6543), enforce SSL
# Example: postgresql://USER:PASSWORD@HOST:6543/DB?sslmode=require&gssencmode=disable
DATABASE_URL=postgresql://user:password@host:6543/database?sslmode=require&gssencmode=disable

# Allowed frontend origin for CORS
FRONTEND_URL=http://localhost:5173

# Enable debug in development; disable in production
DEBUG=true
